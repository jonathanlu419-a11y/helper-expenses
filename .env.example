# ─────────────────────────────────────────────────────────────
# Postgres connection — Neon (Serverless Postgres)
# ─────────────────────────────────────────────────────────────
# The app connects with the standard `pg` driver via DATABASE_URL.
# Neon's free tier runs indefinitely at no cost.
#
# LOCAL DEV: copy this file to `.env.local` and paste your Neon
# **pooled** connection string (Neon console → your project →
# Connection string → "Pooled connection", or the Vercel Storage
# panel for the connected Neon store). It ends with
# `?sslmode=require` (Neon strings may also include
# `channel_binding=require`, which the pg driver handles fine).
#
# VERCEL: the Neon store is attached via the Vercel ↔ Neon
# integration. It injects prefixed vars (e.g.
# helper_expenses_tracking_DATABASE_URL), but this app reads the
# plain DATABASE_URL — set that to the pooled Neon string in the
# project's Environment Variables (Production/Preview/Development).

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Gemini API key — powers the /worker camera Quick Add (Gemini
# vision reads a receipt / price tag to prefill the form) and
# category-label auto-translation (English → Indonesian)
# ─────────────────────────────────────────────────────────────
# Optional: if unset, the camera button is hidden and the Indonesian
# label is left blank for manual entry. Get a key at
# https://aistudio.google.com/apikey.
GEMINI_API_KEY="AIza..."

# ─────────────────────────────────────────────────────────────
# Admin password — gates /admin (the same dashboard as /mum,
# password-protected). /mum itself stays public/unauthenticated.
# ─────────────────────────────────────────────────────────────
# Required for /admin to work at all — without it, /api/admin/login
# returns 503 and the login form can never succeed. Pick any string;
# it's never stored, only compared server-side and used to sign the
# session cookie.
ADMIN_PASSWORD="choose-a-password"
