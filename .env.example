# ─────────────────────────────────────────────────────────────
# Postgres connection — Render Postgres
# ─────────────────────────────────────────────────────────────
# The app connects with the standard `pg` driver via DATABASE_URL.
#
# LOCAL DEV: copy this file to `.env.local` and paste your Render
# database's **External Database URL** (Render dashboard → your
# Postgres instance → "Connections" → External Database URL).
# Render requires SSL; the app enables it automatically for non-local
# hosts, so you do not need to append any sslmode parameter.
#
# VERCEL: set the same DATABASE_URL as an Environment Variable in the
# Vercel project settings (use the External Database URL so Vercel's
# servers can reach Render).

DATABASE_URL="postgres://USER:PASSWORD@dpg-xxxxxxxx-a.oregon-postgres.render.com/DBNAME"
