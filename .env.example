# ─────────────────────────────────────────────────────────────
# Postgres connection (Vercel Postgres / Neon)
# ─────────────────────────────────────────────────────────────
# The app reads POSTGRES_URL (falling back to DATABASE_URL) and connects
# with the Neon serverless driver.
#
# LOCAL DEV: copy this file to `.env.local` and paste the pooled
# connection string from your Postgres provider. It must include
# `?sslmode=require` at the end.
#
# VERCEL: when you attach a Vercel Postgres store to the project,
# these variables are injected automatically — you do NOT need to
# set them by hand there. Only POSTGRES_URL is strictly required
# by this app.

POSTGRES_URL="postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# The following are also provided by Vercel Postgres and are safe to
# include locally if your provider gives them, but are optional here:
# POSTGRES_URL_NON_POOLING="postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# POSTGRES_PRISMA_URL="postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true"
